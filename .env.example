# Copy this file to .env before running docker compose up.
# These defaults are suitable for local development and demos.
# For production, change the database password and SECRET_KEY.

# PostgreSQL settings
POSTGRES_DB=acudb
POSTGRES_USER=acuuser
POSTGRES_PASSWORD=changeme123

# Django secret key.
# Local demo can use any non-empty value, but production should use a strong random string.
SECRET_KEY=your-very-secret-key-change-this
